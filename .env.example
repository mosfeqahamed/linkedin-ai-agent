# Copy to .env and fill in real values

ENVIRONMENT=development
DEBUG=true

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=linkedin_agent

# DeepSeek
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# LinkedIn OAuth (get from https://developer.linkedin.com)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8000/auth/linkedin/callback

# JWT — any long random string
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Fernet key for encrypting LinkedIn tokens at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Frontend origin (for CORS + OAuth redirect after callback)
FRONTEND_ORIGIN=http://localhost:3000
